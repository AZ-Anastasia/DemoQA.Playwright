<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
    <NUnit>
        <!-- Кол-во ядер / 2 (для исключения зависания)-->
        <NumberOfTestWorkers>1</NumberOfTestWorkers>
    </NUnit>

    <Playwright>
        <BrowserName>chromium</BrowserName>
        <LaunchOptions>
            <Headless>true</Headless>
            <Channel>chrome</Channel>
        </LaunchOptions>
    </Playwright>
</RunSettings>